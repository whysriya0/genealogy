// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth Required Models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Genealogy Specific Models
enum PersonType {
  GOD
  KING
  FAMOUS_PERSON
  SAINT
  PERSONAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

model Person {
  id        String     @id @default(cuid())
  name      String
  type      PersonType @default(PERSONAL)
  gender    Gender?
  birthDate DateTime?
  deathDate DateTime?
  isAlive   Boolean    @default(true)

  images String[]

  // Indian Specific Attributes
  region   String?
  culture  String?
  language String?
  caste    String?
  subCaste String?
  gotra    String?

  // Biography / Additional Info
  description String?

  // Social Links
  instagram   String?
  facebook    String?
  linkedin    String?

  relationshipsAsSubject Relationship[] @relation("SubjectRelation")
  relationshipsAsObject  Relationship[] @relation("ObjectRelation")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RelationshipType {
  PARENT_OF
  SPOUSE_OF
  PAST_LIFE_OF
  GURU_OF
}

model Relationship {
  id String @id @default(cuid())

  subjectId String
  subject   Person @relation("SubjectRelation", fields: [subjectId], references: [id], onDelete: Cascade)

  objectId String
  object   Person @relation("ObjectRelation", fields: [objectId], references: [id], onDelete: Cascade)

  type RelationshipType

  isCurrent Boolean? @default(true)

  createdAt DateTime @default(now())

  @@unique([subjectId, objectId, type])
}
